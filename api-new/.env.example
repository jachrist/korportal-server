# SQLite database path (default: ./data/korportal.db)
SQLITE_DB_PATH=./data/korportal.db

# Upload directory for files (PDF, MP3, images)
UPLOAD_DIR=./uploads

# Base URL for serving uploaded files
FILE_BASE_URL=http://localhost:3001/uploads

# Server
PORT=3001

# CORS (comma-separated origins)
CORS_ORIGINS=https://server.kammerkoretutsikten.no,http://localhost:4280,http://localhost:5500

# E-post (for auth codes)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@kammerkoretutsikten.no
SMTP_PASS=
SMTP_FROM=noreply@kammerkoretutsikten.no
